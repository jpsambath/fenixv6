<form method="post" action="{{ path('design_line_style_delete', {'id': line_style.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_method" value="DELETE">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ line_style.id) }}">
    <button class="btn">Delete</button>
</form>
