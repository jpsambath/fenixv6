{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('design_index') }}
{% endblock %}

{% block title %}Design index{% endblock %}

{% block body %}
    {% for msg in app.session.flashBag.get('success') %}
        <div class="alert alert-success">
            {{ msg }}
        </div>
    {% endfor %}

    <div class="pricing-header px-3 py-3 pt-md-5 pb-md-4 mx-auto text-center">
        <h1 class="display-4">Design index</h1>
        <p class="lead"></p>
    </div>

    <div class="container-fluid">
        <div class="card-deck mb-3 text-center">

            <div class="card mb-8 box-shadow">
                <div class="card-header">
                    <h4 class="my-0 font-weight-normal">Design List</h4>
                </div>
                <div class="card-body">

                    <div class="row">
                        <div class="form-group col-4">
                            <select multiple class="js-example-basic-single js-states form-control select-to-apply"
                                    id="selecttag" data-allow-clear="1">

                                {% for tag in tags %}
                                    <option value="{{ tag.id }}">{{ tag.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="form-group col-2">
                            <button id="applytag" class="btn btn-primary btn-block">Apply Tags</button>
                        </div>

                        <div id="activetags" class="form-group col-6 border border-dark rounded">

                        </div>


                    </div>



                    <table id="table"
                           data-toggle="table"
                           data-search="true"
                           data-filter-control="true"
                           data-show-export="true"
                           data-click-to-select="true"
                           data-unique-id="id"
                           data-toolbar="#toolbar"
                           data-show-columns="true"
                           data-id-field="id"
                           data-select-item-name="id"
                           class="table-sm table-borderless table-bordered table-hover">
                        <thead class="thead-light">
                        <tr>
                            <th data-field="state" data-checkbox="true">
                                {# <label> #}
                                {# <input type="checkbox" value="all" name="checkedall" id="checkedall"/> #}
                                {# </label> #}
                            </th>
                            <th data-field="id">Id</th>
                            <th data-field="name" data-filter-control="input" data-sortable="true">Name</th>
                            <th data-field="tags" data-filter-control="input" data-sortable="true">Tags</th>
                            <th data-field="models" data-filter-control="input" data-sortable="true">Models</th>
                            <th data-field="templates" data-filter-control="input" data-sortable="true">Templates</th>
                            <th data-field="actions" >Actions</th>
                        </tr>
                        </thead>
                        <tbody id="designlist">
                        {% for design in designs %}
                            <tr>
                                <td>
                                    {# <label> #}
                                    {# <input type="checkbox" id="{{ design.id }}" value="{{ design.id }}" name="checkeddesign"/> #}
                                    {# </label> #}
                                </td>
                                <td>{{ design.id }}</td>
                                <td>{{ design.name }}</td>

                                <td>{% for tag in design.tags %}
                                        <span class='taglabel'><span href='/design/design/ajaxunlinktag/{{ design.id }}/{{ tag.id}}' class='closebtn unlinktagbtn'>×</span>{{ tag.name }}</span>
                                    {% endfor %}</td>
                                <td>{% for model in design.models %}
                                        {{ model.name }}
                                    {% endfor %}</td>
                                <td>{% for template in design.templates %}
                                        {{ template.name }}
                                    {% endfor %}</td>

                                <td>


                                    <a href="{{ path('design_design_show', {'id': design.id}) }}"><span
                                                class="faicon"><i class="fas fa-eye"></i></span></a>
                                    <a href="{{ path('design_design_edit', {'id': design.id}) }}"><span
                                                class="faicon"><i class="fas fa-edit"></i></span></a>
                                    <a href="{{ path('design_design_delete', {'id': design.id}) }}"><span
                                                class="faicon"><i class="fas fa-trash-alt"></i></span></a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="3">no records found</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>

                    <a href="{{ path('design_design_new') }}" class="btn btn-primary">Create new</a>
                    <a href="{{ path('design_text_new') }}" class="btn btn-secondary">Create new Text</a>
                    <a href="{{ path('design_image_new') }}" class="btn btn-dark">Create new Img</a>

                </div>
            </div>
        </div>

        <footer class="pt-4 my-md-5 pt-md-5 border-top">
            <div class="row">
                <div class="col-12 col-md">
                    <img class="mb-2" src="https://getbootstrap.com/docs/4.0/assets/brand/bootstrap-solid.svg" alt=""
                         width="24" height="24">
                    <small class="d-block mb-3 text-muted">© 2017-2018</small>
                </div>
                <div class="col-6 col-md">
                    <h5>Features</h5>
                    <ul class="list-unstyled text-small">
                        <li><a class="text-muted" href="#">Cool stuff</a></li>
                        <li><a class="text-muted" href="#">Random feature</a></li>
                        <li><a class="text-muted" href="#">Team feature</a></li>
                        <li><a class="text-muted" href="#">Stuff for developers</a></li>
                        <li><a class="text-muted" href="#">Another one</a></li>
                        <li><a class="text-muted" href="#">Last time</a></li>
                    </ul>
                </div>
                <div class="col-6 col-md">
                    <h5>Resources</h5>
                    <ul class="list-unstyled text-small">
                        <li><a class="text-muted" href="#">Resource</a></li>
                        <li><a class="text-muted" href="#">Resource name</a></li>
                        <li><a class="text-muted" href="#">Another resource</a></li>
                        <li><a class="text-muted" href="#">Final resource</a></li>
                    </ul>
                </div>
                <div class="col-6 col-md">
                    <h5>About</h5>
                    <ul class="list-unstyled text-small">
                        <li><a class="text-muted" href="#">Team</a></li>
                        <li><a class="text-muted" href="#">Locations</a></li>
                        <li><a class="text-muted" href="#">Privacy</a></li>
                        <li><a class="text-muted" href="#">Terms</a></li>
                    </ul>
                </div>
            </div>
        </footer>
    </div>

    <script>
        $('.select-to-apply').each(function (idx, ele) {
            $(ele).select2({
                theme: "classic",
                tags: true
            });
        });
    </script>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('design_index') }}

{% endblock %}

