{% extends 'base.html.twig' %}

{% block title %}Text{% endblock %}

{% block body %}
    <h1>Text</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ text.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ text.name }}</td>
            </tr>
            <tr>
                <th>Lines</th>
                <td>{{ text.lines ? text.lines|join(', ') : '' }}</td>
            </tr>
            <tr>
                <th>Length</th>
                <td>{{ text.length }}</td>
            </tr>
            <tr>
                <th>Word_count</th>
                <td>{{ text.wordCount }}</td>
            </tr>
            <tr>
                <th>Genre</th>
                <td>{{ text.genre }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('design_text_index') }}">back to list</a>

    <a href="{{ path('design_text_edit', {'id': text.id}) }}">edit</a>

    {{ include('design/text/_delete_form.html.twig') }}
{% endblock %}
