<form method="post" action="{{ path('design_model_category_delete', {'id': model_category.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_method" value="DELETE">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ model_category.id) }}">
    <button class="btn">Delete</button>
</form>
