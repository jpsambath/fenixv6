{{ form_start(form) }}
<div class="row">
    <div class="col-12">
        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.name) }}</label>
            <div class="col-sm-10">
                {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Model name'}}) }}
            </div>
        </div>

        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.file) }}</label>
            <div class="col-sm-10">
                {% if form.file.vars.data %}
                    {{ form_widget(form.file, {'attr': {'class': 'form-control', 'placeholder': 'Select a file', 'file': form.file.vars.data.filename, 'value' : asset('/images/' ~ form.file.vars.data.filename)}}) }}
                    {{ form_widget(form.src, {'attr': {'class': 'form-control', 'placeholder': 'Select a file'}}) }}
                {% else %}
                    {{ form_widget(form.file, {'attr': {'class': 'form-control', 'placeholder': 'Select a file'}}) }}
                    {{ form_widget(form.src, {'attr': {'class': 'form-control', 'placeholder': 'Select a file'}}) }}

                {% endif %}
            </div>
        </div>

        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.pattern) }}</label>
            <div class="col-sm-10">
                {{ form_widget(form.pattern, {'attr': {'class': 'form-control', 'placeholder': 'Pattern name'}}) }}
            </div>
        </div>

        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.modelCategories) }}</label>
            <div class="col-sm-10">
                {{ form_widget(form.modelCategories, {'attr': {'class': 'form-control', 'placeholder': 'Model Category name'}}) }}
            </div>
        </div>


        <button class="btn">{{ button_label|default('Save') }}</button>
        {{ form_end(form) }}
