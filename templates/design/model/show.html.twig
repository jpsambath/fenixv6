{% extends 'base.html.twig' %}

{% block title %}Model{% endblock %}

{% block body %}
    <h1>Model</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ model.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ model.name }}</td>
            </tr>
            <tr>
                <th>Src</th>
                <td>{{ model.src }}</td>
            </tr>
            <tr>
                <th>Pattern</th>
                <td>{{ model.pattern }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('design_model_index') }}">back to list</a>

    <a href="{{ path('design_model_edit', {'id': model.id}) }}">edit</a>

    {{ include('design/model/_delete_form.html.twig') }}
{% endblock %}
