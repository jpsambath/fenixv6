{% extends 'base.html.twig' %}

{% block title %}Image{% endblock %}

{% block body %}
    <h1>Image</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ image.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ image.name }}</td>
            </tr>
            <tr>
                <th>Src</th>
                <td>{{ image.src }}</td>
            </tr>
            <tr>
                <th>Height</th>
                <td>{{ image.height }}</td>
            </tr>
            <tr>
                <th>Width</th>
                <td>{{ image.width }}</td>
            </tr>
            <tr>
                <th>Size</th>
                <td>{{ image.size }}</td>
            </tr>
            <tr>
                <th>Format</th>
                <td>{{ image.format }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('design_image_index') }}">back to list</a>

    <a href="{{ path('design_image_edit', {'id': image.id}) }}">edit</a>

    {{ include('design/image/_delete_form.html.twig') }}
{% endblock %}
