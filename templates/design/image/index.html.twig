{% extends 'base.html.twig' %}

{% block title %}Image index{% endblock %}

{% block body %}
    <h1>Image index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Src</th>
                <th>Height</th>
                <th>Width</th>
                <th>Size</th>
                <th>Format</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for image in images %}
            <tr>
                <td>{{ image.id }}</td>
                <td>{{ image.name }}</td>
                <td>{{ image.src }}</td>
                <td>{{ image.height }}</td>
                <td>{{ image.width }}</td>
                <td>{{ image.size }}</td>
                <td>{{ image.format }}</td>
                <td>
                    <a href="{{ path('design_image_show', {'id': image.id}) }}">show</a>
                    <a href="{{ path('design_image_edit', {'id': image.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('design_image_new') }}">Create new</a>
{% endblock %}
