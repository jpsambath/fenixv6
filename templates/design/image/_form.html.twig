{{ form_start(form) }}


<div class="row">
    <div class="col-6">
        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.name) }}</label>
            <div class="col-sm-10">
                {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Design name'}}) }}
            </div>
        </div>

        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.genre) }}</label>
            <div class="col-sm-10">
                {{ form_widget(form.genre, {'attr': {'class': 'form-control', 'placeholder': 'Genre'}}) }}
            </div>
        </div>

        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.tags) }}</label>
            <div class="col-sm-10">
                {{ form_widget(form.tags, {'attr': {'class': 'form-control', 'placeholder': 'Tags'}}) }}
            </div>
        </div>

        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.templates) }}</label>
            <div class="col-sm-10">
                {{ form_widget(form.templates, {'attr': {'class': 'form-control', 'placeholder': 'Templates'}}) }}
            </div>
        </div>

        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.models) }}</label>
            <div class="col-sm-10">
                {{ form_widget(form.models, {'attr': {'class': 'form-control', 'placeholder': 'Templates'}}) }}
            </div>
        </div>

    </div>

    <div class="col-6">


        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.src) }}</label>
            <div class="col-sm-10">
                {{ form_widget(form.src, {'attr': {'class': 'form-control', 'placeholder': 'Image'}}) }}
            </div>
        </div>

    </div>
</div>
{{ form_row(form._token) }}
<button class="btn btn-primary">{{ button_label|default('Save') }}</button>
{{ form_end(form, {'render_rest': false}) }}
