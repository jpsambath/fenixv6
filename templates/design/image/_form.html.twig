{{ form_start(form) }}


<div class="row">
    <div class="col-6">
        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.name) }}</label>
            <div class="col-sm-10">
                {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Design name'}}) }}
            </div>
        </div>

        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.tags) }}</label>
            <div class="col-sm-10">
                {{ form_widget(form.tags, {'attr': {'class': 'form-control', 'placeholder': 'Tags'}}) }}
            </div>
        </div>

        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.templates) }}</label>
            <div class="col-sm-10">
                {{ form_widget(form.templates, {'attr': {'class': 'form-control', 'placeholder': 'Templates'}}) }}
            </div>
        </div>

        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.models) }}</label>
            <div class="col-sm-10">
                {{ form_widget(form.models, {'attr': {'class': 'form-control', 'placeholder': 'Models'}}) }}
            </div>
        </div>
        {% if form.file.vars.data %}
            <div class="form-group row">
                <div class="col-sm-10 offset-2 text-center">
                    <img id="imgthumbnail" src="{{ asset('/images/' ~ form.file.vars.data.filename) }}" height="200"
                         width="200" hidden="hidden" class="text-center"/>
                </div>
            </div>
        {% endif %}

    </div>

    <div class="col-6">

        {% if form.file.vars.data %}
            <div class="form-group row">
                <label class="col-sm-2 col-form-label" id="imgsrclbl">{{ form_label(form.file) }}</label>
                <div class="col-sm-10">
                    {{ form_widget(form.file, {'attr': {'class': 'form-control', 'placeholder': 'Image src', 'file': form.file.vars.data.filename, 'value' : asset('/images/' ~ form.file.vars.data.filename)}}) }}
                    {{ form_widget(form.src, {'attr': {'class': 'form-control', 'placeholder': 'Image src'}}) }}

                </div>

            </div>
        {% else %}
            <div class="form-group row">
                <label class="col-sm-2 col-form-label" id="imgfilelbl">{{ form_label(form.file) }}</label>
                <div class="col-sm-10">
                    {{ form_widget(form.file, {'attr': {'class': 'form-control', 'placeholder': 'Image File'}}) }}
                    {{ form_widget(form.src, {'attr': {'class': 'form-control', 'placeholder': 'Image src'}}) }}
                </div>

            </div>

        {% endif %}

        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.height) }}</label>
            <div class="col-sm-10">
                {{ form_widget(form.height, {'attr': {'class': 'form-control', 'placeholder': 'Image height', 'readonly' : 'readonly'}}) }}
            </div>
        </div>

        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.width) }}</label>
            <div class="col-sm-10">
                {{ form_widget(form.width, {'attr': {'class': 'form-control', 'placeholder': 'Image width', 'readonly' : 'readonly'}}) }}
            </div>
        </div>

        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.size) }}</label>
            <div class="input-group col-sm-10">
                {{ form_widget(form.size, {'attr': {'class': 'form-control', 'placeholder': 'Image size', 'readonly' : 'readonly'}}) }}
                <div class="input-group-append">
                    <span class="input-group-text">Ko</span>
                </div>
            </div>
        </div>


        <div class="form-group row">
            <label class="col-sm-2 col-form-label">{{ form_label(form.format) }}</label>
            <div class="col-sm-10">
                {{ form_widget(form.format, {'attr': {'class': 'form-control', 'placeholder': 'Image format', 'readonly' : 'readonly'}}) }}
            </div>
        </div>

    </div>
</div>
{{ form_row(form._token) }}
<button class="btn btn-primary">{{ button_label|default('Save') }}</button>
{{ form_end(form, {'render_rest': false}) }}
